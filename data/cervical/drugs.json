  "treatment_notes": [
    {
      "topic": "Cisplatin Hydration Protocol",
      "detail": "前後 1000-3000 mL 0.9% N/S + 10 mEq KCl + 8 mEq (1 g) MgSO4 各 2 小時。預防腎毒性與電解質失衡。"
    },
    {
      "topic": "Carboplatin 計算公式 (Calvert)",
      "detail": "Dose (mg) = AUC × (CCr + 25)。AUC 4-6 為標準範圍；CCRT 同步時用 AUC 2。"
    },
    {
      "topic": "Bevacizumab 注意事項",
      "detail": "GU/GI fistula 風險上升（特別既往 RT 區域）。手術前後 28 天停用；高血壓 / 蛋白尿需監測。"
    },
    {
      "topic": "Pembrolizumab 免疫相關 AE",
      "detail": "Pneumonitis / hepatitis / colitis / endocrinopathy（甲狀腺、垂體、腎上腺）/ skin rash。需定期 LFT、TFT、cortisol、glucose。"
    },
    {
      "topic": "Topotecan 骨髓抑制",
      "detail": "嚴重 myelosuppression（neutropenia 為主，thrombocytopenia）。給藥前需 ANC ≥ 1500、PLT ≥ 100K。"
    },
    {
      "topic": "HER2 IHC 判讀（IHC 3+ vs 2+）",
      "detail": "IHC 3+：強烈完整膜染色 ≥ 10%。IHC 2+：中等完整膜染色 ≥ 10%，需 ISH (FISH/CISH) 確認 amplification 才視為 HER2-positive。"
    }
  ]
}
